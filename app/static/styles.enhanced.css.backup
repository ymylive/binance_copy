@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap");

:root {
  --bg: #0a0e1a;
  --bg-secondary: #111827;
  --panel: #1a1f35;
  --panel-hover: #1f2540;
  --ink: #f8fafc;
  --muted: #94a3b8;
  --border: #2d3548;
  --accent: #3b82f6;
  --accent-soft: rgba(59, 130, 246, 0.1);
  --accent-hover: #2563eb;
  --accent-glow: rgba(59, 130, 246, 0.3);
  --success: #10b981;
  --success-glow: rgba(16, 185, 129, 0.3);
  --warning: #f59e0b;
  --info: #0ea5e9;
  --danger: #ef4444;
  --danger-glow: rgba(239, 68, 68, 0.3);
  --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --gradient-success: linear-gradient(135deg, #10b981 0%, #059669 100%);
  --gradient-danger: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
  --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
  --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.2);
  --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
  --shadow-glow: 0 0 20px rgba(59, 130, 246, 0.4);
  --radius: 12px;
  --radius-lg: 16px;
}

* {
  box-sizing: border-box;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 5px currentColor, 0 0 10px currentColor;
  }
  50% {
    box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
  }
}

@keyframes slideIn {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes shimmer {
  0% {
    background-position: -1000px 0;
  }
  100% {
    background-position: 1000px 0;
  }
}

body {
  margin: 0;
  font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--ink);
  background: var(--bg);
  background-image:
    radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.1) 0px, transparent 50%),
    radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%);
  background-attachment: fixed;
  animation: fadeIn 0.5s ease-out;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  padding: 20px 48px;
  background: rgba(26, 31, 53, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  box-shadow: var(--shadow);
  position: sticky;
  top: 0;
  z-index: 100;
  animation: slideIn 0.6s ease-out;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16px;
}

.logo {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  background: var(--gradient-primary);
  color: white;
  font-weight: 700;
  box-shadow: var(--shadow-glow);
  transition: all 0.3s ease;
}

.logo:hover {
  transform: scale(1.05) rotate(5deg);
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.6);
}

.title {
  font-size: 20px;
  font-weight: 700;
  background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  color: var(--muted);
  font-size: 13px;
  font-weight: 500;
}

.status-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px 24px;
  min-width: 280px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  box-shadow: var(--shadow);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
  transition: left 0.5s;
}

.status-card:hover::before {
  left: 100%;
}

.status-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
  border-color: var(--accent);
}

.status-main {
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 600;
  font-size: 16px;
}

.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--danger);
  position: relative;
  animation: pulse 2s ease-in-out infinite;
}

.dot::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: inherit;
  animation: glow 2s ease-in-out infinite;
}

.dot.connected {
  background: var(--success);
  animation: none;
}

.dot.connected::before {
  animation: glow 2s ease-in-out infinite;
}

.status-meta {
  display: grid;
  gap: 8px;
  font-size: 12px;
  color: var(--muted);
}

.status-meta div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.status-meta div:last-child {
  border-bottom: none;
}

.status-meta strong {
  color: var(--ink);
  font-weight: 600;
  font-family: "JetBrains Mono", monospace;
}

.status-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.tabs {
  display: flex;
  gap: 8px;
  padding: 8px;
  background: var(--panel);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  margin: 24px 48px;
  box-shadow: var(--shadow);
  animation: fadeIn 0.6s ease-out 0.2s both;
}

.tabs button {
  flex: 1;
  padding: 12px 24px;
  border: none;
  background: transparent;
  color: var(--muted);
  font-weight: 600;
  font-size: 14px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.tabs button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--gradient-primary);
  opacity: 0;
  transition: opacity 0.3s;
  z-index: -1;
}

.tabs button:hover {
  color: var(--ink);
  background: rgba(255, 255, 255, 0.05);
}

.tabs button.active {
  color: white;
  background: var(--gradient-primary);
  box-shadow: var(--shadow-glow);
}

.tabs button.active::before {
  opacity: 1;
}

.layout {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 24px;
  padding: 32px 48px 48px;
  max-width: 1600px;
  margin: 0 auto;
}

.panel {
  grid-column: span 6;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeIn 0.6s ease-out;
  position: relative;
  overflow: hidden;
}

.panel::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--gradient-primary);
  opacity: 0;
  transition: opacity 0.3s;
}

.panel:hover::after {
  opacity: 1;
}

.panel:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(59, 130, 246, 0.3);
}

.panel.wide {
  grid-column: span 12;
}

.panel-head h2 {
  margin: 0 0 6px;
  font-size: 18px;
  font-weight: 700;
  background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.panel-head p {
  margin: 0 0 16px;
  color: var(--muted);
  font-size: 13px;
}

button {
  border: none;
  cursor: pointer;
  border-radius: var(--radius);
  padding: 12px 24px;
  font-weight: 600;
  font-family: "Inter", sans-serif;
  font-size: 14px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

button:hover::before {
  width: 300px;
  height: 300px;
}

button:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

button:active:not(:disabled) {
  transform: translateY(0);
}

button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

button.primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: var(--shadow-glow);
}

button.primary:hover:not(:disabled) {
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.6);
}

button.ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--ink);
  box-shadow: none;
}

button.ghost:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--accent);
}

input,
select {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 16px;
  font-family: "JetBrains Mono", monospace;
  font-size: 13px;
  color: var(--ink);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

input:hover,
select:hover {
  border-color: var(--accent);
  background: var(--panel);
}

input:focus,
select:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft), var(--shadow-glow);
  background: var(--panel);
}

.table {
  display: grid;
  gap: 12px;
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
  color: var(--muted);
}

.table-row {
  display: grid;
  gap: 12px;
  padding: 16px;
  border-radius: var(--radius);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  align-items: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeIn 0.4s ease-out;
}

.table-row:hover {
  background: var(--panel-hover);
  border-color: var(--accent);
  transform: translateX(4px);
  box-shadow: var(--shadow);
}

.table-row.header {
  background: transparent;
  border: none;
  font-weight: 700;
  color: var(--ink);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 11px;
}

.table-row.header:hover {
  transform: none;
  box-shadow: none;
}

.badge {
  padding: 4px 12px;
  border-radius: 999px;
  background: var(--accent-soft);
  color: var(--accent);
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid rgba(59, 130, 246, 0.2);
  transition: all 0.3s;
}

.badge:hover {
  background: var(--accent);
  color: white;
  transform: scale(1.05);
}

.badge.off {
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
  border-color: rgba(239, 68, 68, 0.2);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.action-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  background: var(--bg-secondary);
  display: grid;
  gap: 8px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: var(--success);
  transition: width 0.3s;
}

.action-card:hover::before {
  width: 8px;
}

.action-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--accent);
}

.action-card[data-action="open"]::before {
  background: var(--gradient-success);
}

.action-card[data-action="add"]::before {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
}

.action-card[data-action="reduce"]::before {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.action-card[data-action="close"]::before {
  background: var(--gradient-danger);
}

.action-count {
  font-weight: 700;
  color: var(--ink);
  background: var(--accent-soft);
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 12px;
  border: 1px solid rgba(59, 130, 246, 0.2);
}

.action-symbol {
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
}

.service-dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--muted);
  position: relative;
  transition: all 0.3s;
}

.service-dot::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: inherit;
}

.service-dot.running {
  background: var(--success);
  animation: glow 2s ease-in-out infinite;
}

.service-dot.stopped {
  background: var(--danger);
  animation: pulse 2s ease-in-out infinite;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

label {
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hint {
  border-radius: var(--radius);
  border: 1px dashed var(--border);
  background: var(--bg-secondary);
  padding: 16px;
  position: relative;
  overflow: hidden;
}

.hint::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.1), transparent);
  animation: shimmer 3s infinite;
}

.code-block {
  background: #000;
  color: #10b981;
  border-radius: var(--radius);
  padding: 16px;
  font-size: 12px;
  line-height: 1.6;
  font-family: "JetBrains Mono", monospace;
  overflow-x: auto;
  border: 1px solid rgba(16, 185, 129, 0.2);
  box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
}

.pagination {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8px;
  padding-top: 16px;
  font-size: 12px;
  color: var(--muted);
}

.pagination button {
  border: 1px solid var(--border);
  background: var(--bg-secondary);
  padding: 8px 16px;
  border-radius: var(--radius);
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
  color: var(--ink);
}

.status-dot {
  display: inline-block;
  font-size: 20px;
  line-height: 1;
  animation: pulse 2s ease-in-out infinite;
}

.status-dot.connected {
  color: var(--success);
  animation: glow 2s ease-in-out infinite;
  filter: drop-shadow(0 0 8px var(--success-glow));
}

.status-dot.disconnected {
  color: var(--danger);
  filter: drop-shadow(0 0 8px var(--danger-glow));
}

@media (max-width: 1024px) {
  .topbar {
    flex-direction: column;
    align-items: flex-start;
    padding: 20px 24px;
  }

  .tabs {
    margin: 16px 24px;
    flex-wrap: wrap;
  }

  .layout {
    grid-template-columns: 1fr;
    padding: 24px;
    gap: 16px;
  }

  .panel,
  .panel.wide {
    grid-column: span 1;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .action-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .topbar {
    padding: 16px;
  }

  .tabs {
    margin: 12px 16px;
  }

  .tabs button {
    padding: 10px 16px;
    font-size: 13px;
  }

  .layout {
    padding: 16px;
  }

  .panel {
    padding: 16px;
  }
}

.allocation-summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}

.allocation-stat {
  padding: 20px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: all 0.3s;
}

.allocation-stat:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--accent);
}

.allocation-stat strong {
  font-size: 28px;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.table.projects .table-row {
  grid-template-columns: minmax(120px, 1.2fr) minmax(100px, 1fr) minmax(80px, 0.8fr) minmax(60px, 0.6fr) minmax(50px, 0.5fr) minmax(70px, 0.6fr) minmax(60px, 0.5fr) minmax(100px, 1fr);
}

.table.positions .table-row {
  grid-template-columns: minmax(100px, 1fr) minmax(90px, 0.9fr) minmax(60px, 0.6fr) minmax(70px, 0.7fr) minmax(80px, 0.8fr) minmax(100px, 1fr) minmax(100px, 1fr) minmax(100px, 1fr);
}

.table.leader-positions .table-row {
  grid-template-columns: minmax(80px, 0.6fr) minmax(100px, 1fr) minmax(60px, 0.5fr) minmax(90px, 1fr) minmax(90px, 1fr) minmax(90px, 1fr) minmax(60px, 0.5fr) minmax(80px, 0.8fr);
}

.table.history .table-row {
  grid-template-columns: minmax(60px, 0.6fr) minmax(90px, 0.9fr) minmax(60px, 0.6fr) minmax(80px, 0.8fr) minmax(120px, 1.2fr) minmax(120px, 1.2fr) minmax(70px, 0.7fr);
}

.log-level {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.log-level.info {
  color: var(--info);
}

.log-level.warning {
  color: var(--warning);
}

.log-level.error {
  color: var(--danger);
}
